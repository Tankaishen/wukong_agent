<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Must use Theme.AppCompat (or descendant) because SettingsActivity extends AppCompatActivity.
        NoActionBar because this app has no Activity UI (headless service); the settings screen
        uses PreferenceFragmentCompat which renders its own layout.
    -->
    <style name="Theme.WukongAgent" parent="Theme.AppCompat.NoActionBar" />

    <!-- Transparent theme for PermissionActivity (no visible UI, just permission dialog) -->
    <style name="Theme.WukongAgent.Transparent" parent="Theme.WukongAgent">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>
